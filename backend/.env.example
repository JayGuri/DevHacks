# ARFL Backend — Environment Configuration
# Copy this to .env and update values for production

# JWT
JWT_SECRET=arfl-dev-secret-change-in-production
JWT_EXPIRY_HOURS=24

# Database (SQLite default — override for PostgreSQL in production)
DATABASE_URL=sqlite:///./arfl_backend.db

# Server
PORT=8000
LOG_LEVEL=INFO

# Access Control & Feature Gating
# Set to false to bypass all subscription tier checks (dev bypass).
# RBAC (role checks) are always enforced regardless of this value.
ENFORCE_TIER_RESTRICTIONS=true
